.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.topbar {
  padding: 28rpx 28rpx 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #e7ebf2;
}

.title {
  display: block;
  font-size: 38rpx;
  line-height: 48rpx;
  font-weight: 700;
}

.subtitle {
  display: block;
  margin-top: 4rpx;
  color: #5f6f89;
  font-size: 24rpx;
  line-height: 34rpx;
}

.reset-btn {
  margin: 0;
  width: 112rpx;
  height: 56rpx;
  padding: 0;
  border-radius: 8rpx;
  color: #44546c;
  background: #edf1f7;
  font-size: 24rpx;
  line-height: 56rpx;
}

.reset-btn::after,
.close-btn::after,
.primary-btn::after {
  border: 0;
}

.map {
  width: 100%;
  height: 64vh;
  min-height: 760rpx;
}

.city-list {
  padding: 20rpx 24rpx 180rpx;
  display: flex;
  gap: 14rpx;
  flex-wrap: wrap;
}

.city-chip {
  height: 58rpx;
  padding: 0 18rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  border-radius: 8rpx;
  background: #ffffff;
  color: #26364e;
  font-size: 24rpx;
  box-shadow: 0 2rpx 10rpx rgba(17, 29, 48, 0.06);
}

.city-chip--visited {
  color: #0f6b3d;
  background: #e7f6ed;
}

.dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #8a98ad;
}

.city-chip--visited .dot {
  background: #18a05f;
}

.mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 10;
  display: flex;
  align-items: flex-end;
  background: rgba(12, 19, 32, 0.36);
}

.panel {
  width: 100%;
  padding: 28rpx 28rpx 48rpx;
  border-radius: 16rpx 16rpx 0 0;
  background: #ffffff;
  box-sizing: border-box;
}

.panel-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 24rpx;
}

.city-name {
  display: block;
  font-size: 42rpx;
  line-height: 54rpx;
  font-weight: 700;
}

.province {
  display: block;
  margin-top: 4rpx;
  color: #68758b;
  font-size: 26rpx;
  line-height: 36rpx;
}

.close-btn {
  margin: 0;
  width: 56rpx;
  height: 56rpx;
  padding: 0;
  border-radius: 50%;
  background: #edf1f7;
  color: #44546c;
  font-size: 40rpx;
  line-height: 50rpx;
}

.status-row {
  margin-top: 30rpx;
  padding: 22rpx 0;
  display: flex;
  justify-content: space-between;
  border-top: 1rpx solid #edf0f5;
  border-bottom: 1rpx solid #edf0f5;
}

.status-label {
  color: #68758b;
  font-size: 28rpx;
}

.status {
  color: #7c8798;
  font-size: 28rpx;
  font-weight: 700;
}

.status--visited {
  color: #14864f;
}

.primary-btn {
  margin-top: 28rpx;
  height: 92rpx;
  border-radius: 8rpx;
  color: #ffffff;
  background: #2277d6;
  font-size: 30rpx;
  line-height: 92rpx;
  font-weight: 700;
}

.primary-btn--visited {
  background: #14864f;
}
